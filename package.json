{
  "name": "parrot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "docker compose up -d && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @parrot/db generate",
    "db:push": "pnpm --filter @parrot/db push",
    "db:studio": "pnpm --filter @parrot/db studio",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.2"
  },
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.13.1",
      "onFail": "download"
    }
  },
  "type": "module"
}
