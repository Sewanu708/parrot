<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="x-apple-disable-message-reformatting" />
  <title>Reset your password — Parrot</title>
  <!--[if mso]>
  <style>* { font-family: Arial, sans-serif !important; }</style>
  <![endif]-->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    html, body { margin: 0 !important; padding: 0 !important; width: 100% !important; background-color: #F3F4F6; }
    * { -ms-text-size-adjust: 100%; -webkit-text-size-adjust: 100%; box-sizing: border-box; }
    table, td { mso-table-lspace: 0pt !important; mso-table-rspace: 0pt !important; }
    table { border-spacing: 0 !important; border-collapse: collapse !important; }
    img { -ms-interpolation-mode: bicubic; display: block; border: 0; }
    a { text-decoration: none; }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#F3F4F6; font-family:'Inter',Arial,sans-serif;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F3F4F6;">
    <tr>
      <td align="center" style="padding: 40px 16px 48px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width:540px; background:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);">

          <!-- Header -->
          <tr>
            <td style="background-color: #5A2328; padding: 24px 36px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <img src="{{logoUrl}}"
                      alt="Parrot" height="28" style="height:28px; width:auto; display:block;" />
                  </td>
                  <td align="right" style="font-family:'Inter',Arial,sans-serif; font-size:11px; color:rgba(255,255,255,0.8); white-space:nowrap;">
                    Security Alert
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 28px 36px 32px;">
              <p style="margin:0 0 4px; font-size:14px; color:#8A7E72; font-family:'Inter',Arial,sans-serif;">
                Hello{{#if name}} {{name}}{{/if}},
              </p>
              <p style="margin:0 0 20px; font-size:22px; font-weight:700; color:#090302; line-height:1.3; font-family:'Inter',Arial,sans-serif;">
                Reset your password
              </p>
              <p style="margin:0 0 24px; font-size:14px; line-height:1.7; color:#090302; font-family:'Inter',Arial,sans-serif;">
                We received a request to reset the password for your Parrot account. Please enter the following 6-digit code to proceed:
              </p>

              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td align="center" style="background-color:#F9FAFB; padding: 20px; border-radius: 8px; border: 1px solid #E5E7EB;">
                    <span style="font-size: 32px; font-weight: 700; letter-spacing: 6px; color: #090302; font-family:'Inter',Arial,sans-serif;">
                      {{code}}
                    </span>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 28px; font-size:13px; line-height:1.6; color:#8A7E72; font-family:'Inter',Arial,sans-serif; text-align:center;">
                This code will expire in <strong style="color:#090302;">{{expiresInMins}} minutes</strong>.
              </p>
              
              <p style="margin:0 0 28px; font-size:13px; line-height:1.6; color:#8A7E72; font-family:'Inter',Arial,sans-serif;">
                If you did not request a password reset, please ignore this email or contact support if you have concerns.
              </p>
              
              <p style="margin:0; font-size:14px; line-height:1.7; color:#090302; font-family:'Inter',Arial,sans-serif;">
                Best regards,<br />
                <strong style="color:#5A2328;">Team Parrot</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 0 36px 28px;">
              <div style="height:1px; background:#C8BFC7; margin-bottom:20px;"></div>
              <p style="margin:0; font-size:12px; line-height:1.8; color:#8A7E72; text-align:center; font-family:'Inter',Arial,sans-serif;">
                Need help? Reply to this email or contact support.
              </p>
              <p style="margin:8px 0 0; font-size:11px; color:#8A7E72; text-align:center; font-family:'Inter',Arial,sans-serif;">
                &copy; {{year}} Parrot. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
